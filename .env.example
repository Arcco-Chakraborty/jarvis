PORT=3000
ESP32_BASE_URL=http://192.168.1.50
PC_AGENT_TOKEN=change-me
# Remote PC agent(s): comma-separated name=baseUrl. Spoken as "on the <name>".
PC_AGENTS=laptop=http://192.168.1.60:7000
GEMINI_API_KEY=your-gemini-key-here
# Optional: comma-separated keys for round-robin rotation (overrides GEMINI_API_KEY)
GEMINI_API_KEYS=

# Voice service
ORCHESTRATOR_URL=http://localhost:3000
# Wake word: openWakeWord, bundled "hey jarvis" model (fully local, no account)
VOICE_WAKE_BACKEND=openwakeword
VOICE_WAKE_THRESHOLD=0.35
# STT: GPU faster-whisper, open vocabulary
VOICE_STT_BACKEND=whisper
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8
VOICE_VAD_AGGRESSIVENESS=2
VOICE_VAD_SILENCE_MS=800
VOICE_NO_SPEECH_THRESHOLD=0.6
VOICE_LOGPROB_THRESHOLD=-1.0
VOICE_TTS_BACKEND=piper
PIPER_COMMAND=.venv/bin/piper
PIPER_VOICE=voice-service/models/en_GB-alan-medium.onnx
AUDIO_PLAYER=aplay
# Conversation loop tuning
VOICE_RECORD_SECONDS=4
VOICE_FOLLOWUP_SECONDS=5
VOICE_MAX_UTTERANCE_SECONDS=12
VOICE_COOLDOWN_S=1.2
# Vosk fallback STT (only used when VOICE_STT_BACKEND=vosk)
VOSK_MODEL_PATH=voice-service/models/vosk-model-en-us-0.22-lgraph
VOICE_MIN_CONFIDENCE=0.4
# Voice client HTTP timeout for /command — must exceed the orchestrator's
# slowest Gemini path (vision ~12s). Too low -> false "couldn't reach".
VOICE_REQUEST_TIMEOUT_S=30

# Phone camera (IP Webcam app snapshot URL). Embed user:pass@ if it needs auth.
PHONE_CAMERA_URL=http://PHONE_IP:8080/photo.jpg
